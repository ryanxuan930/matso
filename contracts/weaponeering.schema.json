{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "matso:weaponeering:0.1.0",
  "title": "EquipmentBaseStats",
  "description": "EquipmentTemplate.baseStats 的驗證 schema（SPEC_FULL §7.1）。裁決引擎為資料驅動：公式讀這裡，不寫死參數。依 category 選用對應 $defs。",
  "$defs": {
    "armor_class": {
      "description": "裝甲級別標準詞彙（damage_by_armor_class 的鍵建議取自此集，供不同武器一致對照）。此為建議詞彙，非封閉限制——damage_by_armor_class 仍允許自訂鍵以保留可擴充性。",
      "type": "string",
      "enum": [
        "INFANTRY",
        "LIGHT_VEHICLE",
        "ARMOR",
        "FORTIFICATION",
        "STRUCTURE",
        "AIRCRAFT",
        "ROTARY_WING",
        "NAVAL_SURFACE",
        "UAS"
      ]
    },
    "kinetic": {
      "type": "object",
      "required": ["max_range_m", "ph_by_range_band", "damage_by_armor_class", "ammo_types"],
      "properties": {
        "max_range_m": { "type": "number", "exclusiveMinimum": 0 },
        "min_range_m": { "type": "number", "minimum": 0, "default": 0 },
        "indirect_fire": { "type": "boolean", "default": false },
        "kinetic_kind": {
          "description": "動能武器細分（現代軍事分類），驅動 UI 預設與子型行為。MORTAR/MLRS 屬 artillery 類別。",
          "enum": ["SMALL_ARMS", "AUTOCANNON", "ATGM", "TANK_MAIN_GUN", "GRENADE", "GENERIC"],
          "default": "GENERIC"
        },
        "rate_of_fire_rpm": {
          "description": "實際每分鐘發數；per-tick 由想定 tick 秒數換算（取代把 tick 長度寫死進 rate_per_tick）。",
          "type": "number",
          "exclusiveMinimum": 0
        },
        "guided": {
          "description": "導引武器（如 ATGM）——命中率近乎與距離無關。",
          "type": "boolean",
          "default": false
        },
        "penetration_type": {
          "description": "穿甲機制（KE 隨距衰減、HEAT 平坦）。v0 選填。",
          "enum": ["KE", "HEAT", "HE_FRAG", "NONE"]
        },
        "ph_by_range_band": {
          "type": "array",
          "description": "由近到遠的 [range_max_m, base_ph] 對；區間內依 ph_interp 插值",
          "items": { "type": "array", "prefixItems": [{ "type": "number" }, { "type": "number", "minimum": 0, "maximum": 1 }] },
          "minItems": 1
        },
        "ph_interp": {
          "description": "命中率對射程的插值法：linear＝控制點間線性；polynomial＝拉格朗日多項式穿過全部控制點（曲線平滑，需 ≥3 點才有意義）。",
          "enum": ["linear", "polynomial"],
          "default": "linear"
        },
        "damage_by_armor_class": {
          "type": "object",
          "description": "armor_class → damage（healthStatus 扣點）。鍵建議取自 $defs.armor_class 詞彙，但允許自訂鍵（可擴充）。",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "pk_by_armor_class": {
          "type": "object",
          "description": "armor_class → 每發擊殺機率 P(kill|hit) ∈ [0,1]（真實化交戰）。有值時命中造成期望傷亡＝pk×每平台戰力（漸進消耗）；無值則引擎退回 damage_by_armor_class/100 相容既有種子。",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "ammo_types": { "type": "array", "items": { "type": "string" } },
        "rate_per_tick": { "type": "number", "exclusiveMinimum": 0, "default": 1 }
      }
    },
    "sensor": {
      "type": "object",
      "required": ["sensor_kind", "max_range_m", "detect_curve"],
      "properties": {
        "sensor_kind": { "enum": ["OPTICAL", "IR", "RADAR", "ACOUSTIC", "SIGINT"] },
        "max_range_m": { "type": "number", "exclusiveMinimum": 0 },
        "detect_curve": {
          "type": "array",
          "description": "[range_max_m, p_detect] 對；DETECTED→CLASSIFIED→IDENTIFIED 升級門檻由引擎係數推導",
          "items": { "type": "array", "prefixItems": [{ "type": "number" }, { "type": "number", "minimum": 0, "maximum": 1 }] }
        }
      }
    },
    "comms": {
      "type": "object",
      "required": ["band", "tx_power_dbm", "rx_sensitivity_dbm"],
      "properties": {
        "band": { "enum": ["LORA", "MESHTASTIC", "VHF", "UHF", "SATCOM"] },
        "tx_power_dbm": { "type": "number" },
        "rx_sensitivity_dbm": { "type": "number" },
        "antenna_gain_dbi": { "type": "number", "default": 0 },
        "mesh_capable": { "type": "boolean", "default": false }
      }
    },
    "logistics": {
      "type": "object",
      "required": ["capacity"],
      "properties": {
        "capacity": {
          "type": "object",
          "description": "supply_class → 攜行量（AMMO/FUEL/WATER_FOOD/BATTERY）",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "transport": {
          "type": "object",
          "description": "運輸能力：載員/載具槽位/可否拖曳。",
          "properties": {
            "troop_capacity": { "type": "integer", "minimum": 0 },
            "vehicle_slots": { "type": "integer", "minimum": 0 },
            "can_tow": { "type": "boolean", "default": false },
            "towable_classes": { "type": "array", "items": { "type": "string" } },
            "load_unload_ticks": { "type": "integer", "minimum": 0, "default": 0 }
          }
        },
        "mobility": { "$ref": "#/$defs/mobility" }
      }
    },
    "mobility": {
      "type": "object",
      "description": "共用機動性區塊（載具/自走砲/後勤車輛嵌入）：能否自走、機動類型、道路/越野速度。",
      "properties": {
        "can_self_move": { "type": "boolean", "default": true },
        "mobility_class": {
          "enum": ["WHEELED", "TRACKED", "TOWED", "MAN_PORTABLE", "STATIC", "AIR"]
        },
        "max_road_speed_kmh": { "type": "number", "minimum": 0 },
        "max_cross_country_speed_kmh": { "type": "number", "minimum": 0 },
        "fuel_burn_per_tick": { "type": "number", "minimum": 0, "default": 0 }
      }
    },
    "artillery": {
      "type": "object",
      "description": "火砲類（間瞄）：迫砲/牽引砲/自走砲/火箭。allOf 併入 kinetic 火力欄位再加火砲諸元。",
      "allOf": [{ "$ref": "#/$defs/kinetic" }],
      "properties": {
        "artillery_kind": { "enum": ["MORTAR", "TOWED_GUN", "SP_GUN", "MLRS"] },
        "dispersion_cep_m": { "type": "number", "minimum": 0, "description": "圓形公算誤差（散布）m。" },
        "lethal_radius_m": { "type": "number", "minimum": 0, "description": "彈著致命半徑 m（面殺傷）。" },
        "rounds_per_mission": { "type": "integer", "exclusiveMinimum": 0 },
        "reload_ticks": { "type": "integer", "minimum": 0, "default": 0 },
        "emplace_ticks": { "type": "integer", "minimum": 0, "default": 0 },
        "mobility": { "$ref": "#/$defs/mobility" }
      }
    },
    "vehicle": {
      "type": "object",
      "description": "載具（戰車/IFV/APC）：組員/載員、各面裝甲、機動性、防禦裝甲級別。",
      "required": ["mobility"],
      "properties": {
        "crew": { "type": "integer", "minimum": 0 },
        "passenger_capacity": { "type": "integer", "minimum": 0, "default": 0 },
        "armor_class": { "$ref": "#/$defs/armor_class" },
        "armor_by_aspect_mm": {
          "type": "object",
          "description": "各面裝甲厚度（RHA 等效 mm）。",
          "properties": {
            "front": { "type": "number", "minimum": 0 },
            "side": { "type": "number", "minimum": 0 },
            "rear": { "type": "number", "minimum": 0 },
            "top": { "type": "number", "minimum": 0 }
          }
        },
        "mobility": { "$ref": "#/$defs/mobility" }
      }
    },
    "drone": {
      "type": "object",
      "required": ["endurance_ticks", "cruise_speed_ms", "weather_limits"],
      "properties": {
        "endurance_ticks": { "type": "integer", "exclusiveMinimum": 0 },
        "cruise_speed_ms": { "type": "number", "exclusiveMinimum": 0 },
        "weather_limits": {
          "type": "object",
          "properties": {
            "max_wind_ms": { "type": "number" },
            "min_visibility_m": { "type": "number" }
          }
        }
      }
    }
  }
}
