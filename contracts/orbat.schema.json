{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "matso:orbat:0.1.0",
  "title": "OrbatFile",
  "description": "單一陣營的戰鬥序列（orbat/<faction>.yaml，SPEC_FULL §11.1）。巢狀單位樹以 parent 參照。",
  "type": "object",
  "required": ["faction", "units"],
  "additionalProperties": false,
  "properties": {
    "faction": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,31}$" },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["designation", "unit_level"],
        "additionalProperties": false,
        "properties": {
          "designation": { "type": "string", "minLength": 1 },
          "unit_level": {
            "enum": [
              "THEATER", "CORPS", "DIVISION", "BRIGADE", "BATTALION",
              "COMPANY", "PLATOON", "SQUAD", "FIRETEAM", "INDIVIDUAL"
            ]
          },
          "lat": { "type": "number", "minimum": -90, "maximum": 90 },
          "lng": { "type": "number", "minimum": -180, "maximum": 180 },
          "parent": { "type": "string", "description": "上級單位 designation（同 orbat 內）" }
        }
      }
    }
  }
}
