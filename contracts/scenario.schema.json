{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "matso:scenario:0.1.0",
  "title": "ScenarioPackage",
  "description": "scenario.yaml 的驗證 schema（SPEC_FULL §11.1、§12.1）。載入器 MUST 回報精確錯誤路徑。orbat 各檔見 orbat.schema.json；roe/msel 的 $defs 於 O7.2/O7.3 補完。",
  "type": "object",
  "required": ["name", "version", "bbox", "mode", "tick_rate_ms", "factions", "victory_conditions"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "bbox": {
      "type": "array",
      "description": "[min_lng, min_lat, max_lng, max_lat] WGS84",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    },
    "mode": { "enum": ["REALTIME", "WEGO", "IGO_UGO"] },
    "tick_rate_ms": { "type": "integer", "minimum": 100, "default": 1000 },
    "hex_resolution": { "type": "integer", "minimum": 7, "maximum": 9, "default": 8 },
    "aggregate_adjudication_level": {
      "enum": ["BATTALION", "BRIGADE", "DIVISION"],
      "default": "BATTALION",
      "description": "此層級(含)以上使用 Lanchester 聚合裁決（SPEC_FULL §7.1）"
    },
    "factions": {
      "type": "array",
      "description": "本局交戰陣營宣告（SPEC §12.1/ADR 006）。WHITE_CELL 為統裁保留字，不得列入。",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,31}$" },
          "display_name": { "type": "string" },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
        }
      }
    },
    "relations": {
      "type": "array",
      "description": "陣營關係上三角宣告（對稱）。未宣告配對預設 HOSTILE。",
      "items": {
        "type": "array",
        "prefixItems": [
          { "type": "string" },
          { "type": "string" },
          { "enum": ["ALLIED", "NEUTRAL", "HOSTILE"] }
        ],
        "minItems": 3,
        "maxItems": 3
      }
    },
    "victory_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["faction", "condition"],
        "properties": {
          "faction": { "type": "string", "description": "須為 factions 宣告的陣營 id（載入器語意驗證）" },
          "condition": { "type": "object", "description": "條件 DSL 於 O7.2 定義（與 MSEL trigger 共用）" }
        }
      }
    },
    "files": {
      "type": "object",
      "description": "package 內各檔的相對路徑宣告（orbat 每陣營一檔）",
      "properties": {
        "orbat": {
          "type": "object",
          "description": "faction id → orbat yaml 相對路徑",
          "additionalProperties": { "type": "string" }
        },
        "roe": { "type": "string", "default": "roe.yaml" },
        "msel": { "type": "string", "default": "msel.yaml" },
        "weather_script": { "type": "string" },
        "overrides_dir": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
