{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "matso:scenario:0.1.0",
  "title": "ScenarioPackage",
  "description": "scenario.yaml 的驗證 schema（SPEC_FULL §11.1）。orbat/roe/msel 各檔的 $defs 於 M7-1 補完。載入器 MUST 回報精確錯誤路徑。",
  "type": "object",
  "required": ["name", "version", "bbox", "mode", "tick_rate_ms", "victory_conditions"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "bbox": {
      "type": "array",
      "description": "[min_lng, min_lat, max_lng, max_lat] WGS84",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    },
    "mode": { "enum": ["REALTIME", "WEGO", "IGO_UGO"] },
    "tick_rate_ms": { "type": "integer", "minimum": 100, "default": 1000 },
    "hex_resolution": { "type": "integer", "minimum": 7, "maximum": 9, "default": 8 },
    "aggregate_adjudication_level": {
      "enum": ["BATTALION", "BRIGADE", "DIVISION"],
      "default": "BATTALION",
      "description": "此層級(含)以上使用 Lanchester 聚合裁決（SPEC_FULL §7.1）"
    },
    "victory_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["faction", "condition"],
        "properties": {
          "faction": { "enum": ["BLUE", "RED"] },
          "condition": { "type": "object", "description": "條件 DSL 於 M7-1 定義（與 MSEL trigger 共用）" }
        }
      }
    },
    "files": {
      "type": "object",
      "description": "package 內各檔的相對路徑宣告",
      "properties": {
        "orbat_blue": { "type": "string", "default": "orbat/blue.yaml" },
        "orbat_red": { "type": "string", "default": "orbat/red.yaml" },
        "roe": { "type": "string", "default": "roe.yaml" },
        "msel": { "type": "string", "default": "msel.yaml" },
        "weather_script": { "type": "string" },
        "overrides_dir": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
